# ==========================================================
# Safe downloader (Close + Volume, handles single & MultiIndex)
# ==========================================================
def safe_download(tickers, start, end):
    df = yf.download(
        tickers, start=start, end=end,
        progress=False, auto_adjust=True, group_by="ticker"
    )
    px, vol = pd.DataFrame(), pd.DataFrame()

    # For multiple tickers - Dataframe is MultiIndex
    if isinstance(df.columns, pd.MultiIndex):
        for t in tickers:
            if t in df.columns.get_level_values(0):
                tdf = df[t]
                if "Close" in tdf and "Volume" in tdf:
                    px[t]  = tdf["Close"]
                    vol[t] = tdf["Volume"]
    else:
        # For single ticker
        if "Close" in df and "Volume" in df:
            t = tickers[0]
            px[t]  = df["Close"]
            vol[t] = df["Volume"]

    px.dropna(how="all", inplace=True)
    vol.dropna(how="all", inplace=True)
    px, vol = px.align(vol, join="inner", axis=0)
    return px, vol


# ==========================================================
# Metrics / Benchmark / Attribution / Trades
# ==========================================================
# Calculate metrics for Total return, Compound annual growth rate CAGR, Sharpe, Sortino, Calmar, Max Drawdown
def calc_metrics(daily_ret, equity, init_cap: float):
    # Ensure daily_ret is a 1-D Series (equal-weight across cols if needed)
    if isinstance(daily_ret, pd.DataFrame):
        if daily_ret.shape[1] == 1:
            daily_ret = daily_ret.iloc[:, 0]
        else:
            daily_ret = daily_ret.mean(axis=1)
    daily_ret = daily_ret.dropna()

    equity = equity.dropna()
    total_ret = float(equity.iloc[-1] / init_cap - 1.0) if len(equity) else np.nan

    days = len(equity)
    if days >= 2:
        cagr = float((equity.iloc[-1] / equity.iloc[0]) ** (252 / days) - 1.0)
    else:
        cagr = np.nan

    # Force scalars
    vol = float(daily_ret.std() * np.sqrt(252)) if len(daily_ret) > 1 else np.nan
    mean_ann = float(daily_ret.mean() * 252) if len(daily_ret) else np.nan
    sharpe = (mean_ann / vol) if (pd.notna(vol) and vol > 0) else np.nan

    dd = float((equity / equity.cummax() - 1).min()) if len(equity) else np.nan
    calmar = (cagr / abs(dd)) if (pd.notna(cagr) and pd.notna(dd) and dd < 0) else np.nan

    dn = float(daily_ret[daily_ret < 0].std()) if len(daily_ret) else np.nan
    sortino = (mean_ann / (dn * np.sqrt(252))) if (pd.notna(dn) and dn > 0) else np.nan

    return dict(
        Total_Return=total_ret, CAGR=cagr, Sharpe=sharpe,
        Sortino=sortino, Calmar=calmar, MaxDD=dd,
        Ann_Mean=mean_ann, Ann_Std_Dev=vol
    )


# Helper function: Compute maximum drawdown duration (in trading days)
def max_drawdown_duration(equity: pd.Series) -> int:
    """
    Calculates the maximum number of consecutive days the portfolio remained under water.
    """
    dd = equity / equity.cummax() - 1
    draw = (dd < 0).astype(int)
    duration = draw.groupby((draw != draw.shift()).cumsum()).cumsum()
    return int(duration.max())

# Compare to SPY as benchmark, find Alpha, Beta, Information Ratio
def benchmark_compare(portfolio_daily_ret, start, end, symbol="SPY"):
    bench = yf.download(symbol, start=start, end=end, progress=False, auto_adjust=True)
    bench_ret = bench["Close"].pct_change().dropna()
    aligned = pd.concat([portfolio_daily_ret, bench_ret], axis=1).dropna()
    aligned.columns = ["Portfolio", "Benchmark"]

    if aligned["Benchmark"].var() > 0:
        cov = np.cov(aligned["Portfolio"], aligned["Benchmark"])[0, 1]
        beta = cov / aligned["Benchmark"].var()
    else:
        beta = np.nan

    alpha = (aligned["Portfolio"].mean() * 252) - (0 if np.isnan(beta) else beta * aligned["Benchmark"].mean() * 252)

    excess = aligned["Portfolio"] - aligned["Benchmark"]
    ir = (excess.mean() / excess.std()) * np.sqrt(252) if excess.std() > 0 else np.nan

    ann_return = aligned["Portfolio"].mean() * 252
    treynor = (ann_return) / beta if (pd.notna(beta) and beta != 0) else np.nan

    return alpha, beta, ir, treynor, aligned


# Find individual stocks' contribution to performance (based on Returns & Sharpe)
def per_ticker_attribution(price: pd.DataFrame, positions: pd.DataFrame):
    """
    Returns per ticker (column-wise):
      - Return_Contribution: total multiplicative contribution minus 1
      - Sharpe_Contribution: ticker-level Sharpe using its own active return stream
    """
    rets = price.pct_change()
    strat = positions.shift(1) * rets  # per-ticker active P&L stream

    # Multiplicative contribution per ticker
    total_return_contrib = (1.0 + strat).cumprod().iloc[-1] - 1.0

    # Ticker Sharpe
    sharpe_contrib = (strat.mean() * 252) / (strat.std() * np.sqrt(252))

    return pd.DataFrame({
        "Return_Contribution": total_return_contrib,
        "Sharpe_Contribution": sharpe_contrib
    })


# Plot individual stocks' contribution to performance (one chart for Sharpe and one for Return Contribution, then print attribution table)
def plot_per_ticker_attribution(price: pd.DataFrame, positions: pd.DataFrame):
    attr = per_ticker_attribution(price, positions).sort_values(
        "Sharpe_Contribution", ascending=True
    )
    plt.figure(figsize=(10, 6))
    plt.barh(attr.index, attr["Sharpe_Contribution"], color="steelblue")
    plt.title("Per-Ticker Sharpe Contribution")
    plt.xlabel("Sharpe Contribution")
    plt.grid(axis="x", linestyle="--", alpha=0.5)
    plt.show()

    # Return contribution chart
    plt.figure(figsize=(10, 5))
    attr["Return_Contribution"].sort_values().plot(kind="barh", color="steelblue")
    plt.title("Per-Ticker Return Contribution")
    plt.xlabel("Contribution (Total)")
    plt.grid(axis="x", linestyle="--", alpha=0.5)
    plt.show()

    print("\n=== Per-Ticker Attribution Table ===")
    print(attr)


# Determine the trades of each stock
def extract_trades(positions: pd.Series, prices: pd.Series) -> pd.DataFrame:
    """
    For a single ticker's position series {-1,0,1} and price series,
    return trades with Entry/Exit/Side/EntryPx/ExitPx/Return.
    """
    trades = []
    pos = positions.fillna(0).astype(int)
    change_idx = pos[pos != pos.shift(1)].index

    for i, dt in enumerate(change_idx):
        new = pos.loc[dt]
        if new == 0:
            continue
        side = int(new)
        entry_date = dt
        entry_price = float(prices.loc[entry_date])

        exit_date = change_idx[i + 1] if i + 1 < len(change_idx) else prices.index[-1]
        exit_price = float(prices.loc[exit_date])

        ret = (exit_price / entry_price - 1.0) * side
        trades.append([entry_date, exit_date, side, entry_price, exit_price, ret])

    return pd.DataFrame(trades, columns=["Entry", "Exit", "Side", "EntryPx", "ExitPx", "Return"])

# Helper function: Aggregate trade statistics (count, win-rate, avg returns, expectancy)
def trade_statistics(positions: pd.DataFrame, prices: pd.DataFrame) -> dict:
    """
    Aggregates total trade stats across all tickers:
      - Total Trades
      - Win Rate
      - Average Win / Loss
      - Expectancy (expected return per trade)
    """
    total_trades, wins, losses, returns = 0, 0, 0, []

    for t in positions.columns:
        trades = extract_trades(positions[t], prices[t])
        if trades.empty:
            continue
        total_trades += len(trades)
        trade_rets = trades["Return"].dropna()
        returns.extend(trade_rets)
        wins += (trade_rets > 0).sum()
        losses += (trade_rets < 0).sum()

    if total_trades == 0:
        return {
            "Total_Trades": 0,
            "Win_Rate": np.nan,
            "Avg_Win": np.nan,
            "Avg_Loss": np.nan,
            "Expectancy": np.nan
        }

    win_rate = wins / total_trades
    avg_win = np.mean([r for r in returns if r > 0]) if wins > 0 else 0
    avg_loss = np.mean([r for r in returns if r < 0]) if losses > 0 else 0
    expectancy = (win_rate * avg_win) + ((1 - win_rate) * avg_loss)

    return {
        "Total_Trades": total_trades,
        "Win_Rate": win_rate,
        "Avg_Win": avg_win,
        "Avg_Loss": avg_loss,
        "Expectancy": expectancy
    }

# ==========================================================
# Backtester (EMA-OBV + dual MA trend + target-vol scaling)
# ==========================================================
class EMA_OBV_Portfolio:
    def __init__(self, tickers, start, end,
                 initial_capital=500000,
                 lambda_=0.990,
                 weighted=False,                           # Default unweighted EMA OBV
                 vol_window=30,
                 ma_window=50,
                 use_dual_ma=True,                         # Allow Primary confirmation gate 50/200 MA confirmation
                 allow_divergence_near_cross=True,         # Allow secondary confirmation gate: Override dual MA trend signals for divergence signals if 50/200 Day MAs are close
                 near_cross_tol=0.01,                      # Condition for secondary gate: 50/200 MAs are within 1% of price
                 target_ann_vol=0.20,                      # Set target volatility for the portfolio as 0.20
                 cost_per_turnover=0.0):
        self.tickers = tickers
        self.start, self.end = start, end
        self.initial_capital = initial_capital
        self.lambda_ = float(lambda_)
        self.alpha = 1.0 - self.lambda_
        self.weighted = bool(weighted)
        self.vol_window = int(vol_window)
        self.ma_window = int(ma_window)
        self.use_dual_ma = bool(use_dual_ma)
        self.allow_divergence_near_cross = bool(allow_divergence_near_cross)
        self.near_cross_tol = float(near_cross_tol)
        self.target_ann_vol = float(target_ann_vol)
        self.cost_per_turnover = float(cost_per_turnover)

        self.price = None
        self.volume = None
        self.obv = None
        self.smoothed_obv = None
        self.signals = None
        self.positions = None
        self.portfolio = None

    # Loading Data
    def load_data(self):
        self.price, self.volume = safe_download(self.tickers, self.start, self.end)
        return self.price, self.volume

    # OBV (raw + EMA-smoothed) computation
    def compute_obv_smoothed(self):
        px, vol = self.price, self.volume
        obv = pd.DataFrame(index=px.index, columns=px.columns, dtype=float)
        sm  = pd.DataFrame(index=px.index, columns=px.columns, dtype=float)

        for t in self.tickers:
            if t not in px.columns:
                continue
            c = px[t].ffill()
            v = vol[t].ffill()

            if self.weighted:
                w = c.diff() / c.shift(1)
                raw = (w * v).cumsum()
            else:
                d = np.sign(c.diff()).fillna(0)
                raw = (d * v).cumsum()

            obv[t] = raw
            sm[t]  = raw.ewm(alpha=self.alpha, adjust=False).mean()

        self.obv, self.smoothed_obv = obv, sm
        return obv, sm

    # Signals (confirmation + dual-trend mask + gated divergence)
    def generate_signals(self):
        px, sm = self.price, self.smoothed_obv
        sig = pd.DataFrame(0.0, index=px.index, columns=px.columns)

        # daily direction signs
        price_dir = px.diff().apply(np.sign)
        obv_dir   = sm.diff().apply(np.sign)

        for t in self.tickers:
            if t not in px.columns:
                continue

            s = pd.Series(0.0, index=px.index)

            # Generate initial signals: EMA OBV-Price
            s.loc[(price_dir[t] > 0) & (obv_dir[t] > 0)] =  1.0
            s.loc[(price_dir[t] < 0) & (obv_dir[t] < 0)] = -1.0
            s.loc[(price_dir[t] < 0) & (obv_dir[t] > 0)] =  1.0
            s.loc[(price_dir[t] > 0) & (obv_dir[t] < 0)] = -1.0

            # Trend masks
            ma_short = px[t].rolling(self.ma_window, min_periods=self.ma_window).mean()
            trend_short_up   = px[t] > ma_short
            trend_short_down = px[t] < ma_short

            # Primary Confirmation Gate
            if self.use_dual_ma: #If dual confirmation of 50/200 Day MA is required
                ma_long = px[t].rolling(200, min_periods=200).mean()
                trend_long_up   = px[t] > ma_long
                trend_long_down = px[t] < ma_long

                # STRICT dual confirmation: require both 50/200 Day MAs to agree
                s = s.where(
                    ((s == 1.0)  & trend_short_up  & trend_long_up) |
                    ((s == -1.0) & trend_short_down & trend_long_down),
                    0.0
                )
            else:# If Only MA50 confirmation
                s = s.where(
                    ((s == 1.0) & trend_short_up) |
                    ((s == -1.0) & trend_short_down),
                    0.0
                )

            # Secondary Confirmation Fate: gated divergence near MA(50)~MA(200) cross
            if self.use_dual_ma and self.allow_divergence_near_cross:
                ma_long = px[t].rolling(200, min_periods=200).mean()
                near_cross = (ma_short - ma_long).abs() < (self.near_cross_tol * px[t])

                # Recompute single-series dirs to avoid accidental frame alignment issues
                pdir = px[t].diff().apply(np.sign)
                odir = sm[t].diff().apply(np.sign)

                # Override primary gate signals for initial divergence signals
                bullish_div = (pdir < 0) & (odir > 0) & near_cross
                bearish_div = (pdir > 0) & (odir < 0) & near_cross

                s.loc[bullish_div] = 1.0
                s.loc[bearish_div] = -1.0

            sig[t] = s.fillna(0.0)

        self.signals = sig
        return sig

    # Positions (hold-until-change + target vol scaling)
    def build_positions(self):
        pos = self.signals.replace(0, np.nan).ffill().fillna(0.0)

        if self.vol_window and self.vol_window > 0:
            rets = self.price.pct_change()
            rolling_vol = rets.rolling(self.vol_window).std()
            target = self.target_ann_vol / np.sqrt(252)
            scale = (target / rolling_vol).clip(0.5, 2.0)
            pos = pos * scale

        self.positions = pos
        return pos

    # Portfolio (simple equal-weighting across active names)
    def compute_portfolio(self):
        rets = self.price.pct_change()
        strat = self.positions.shift(1) * rets

        active = strat.notna().sum(axis=1).replace(0, np.nan)
        gross_ret = (strat.sum(axis=1) / active).fillna(0.0)

        # simple transaction cost via turnover
        turnover = (self.positions.diff().abs().sum(axis=1)
                    / self.positions.notna().sum(axis=1)).fillna(0.0)
        net_ret = gross_ret - self.cost_per_turnover * turnover

        equity = (1.0 + net_ret).cumprod() * self.initial_capital
        self.portfolio = pd.DataFrame({"daily_return": net_ret, "equity": equity})
        return self.portfolio

    # Run functions to compute portfolio
    def run(self, price=None, volume=None):
        if price is None or volume is None:
            self.load_data()
        else:
            self.price, self.volume = price, volume
        self.compute_obv_smoothed()
        self.generate_signals()
        self.build_positions()
        return self.compute_portfolio()


# ==========================================================
# Walk-forward (expanding) + Expanding-window summary
# ==========================================================
def expanding_window_test(tickers, start, end, weighted,
                        lambda_grid=(0.94, 0.97, 0.99, 0.995),
                        volw_grid=(0, 30, 60, 120),
                        ma_window=50,
                        first_test_year=2012,
                        cost_per_turnover=0.0,
                        target_ann_vol=0.20,
                        use_dual_ma=True,
                        allow_divergence_near_cross=True):
    price, volume = safe_download(tickers, start, end)
    all_years = sorted({d.year for d in price.index})
    test_years = [y for y in all_years if y >= first_test_year]

    stitched_eq = pd.Series(dtype=float)
    yearly_rows, param_rows = [], []

    for y in test_years:
        train_px = price.loc[:f"{y-1}-12-31"]
        test_px  = price.loc[f"{y}-01-01":f"{y}-12-31"] #1 year testing period
        if len(test_px) < 50:
            continue

        # Find best model based on performance on training data with grid search - Expanding window
        best, best_sharpe = None, -1e9
        for lam in lambda_grid: # Grid search on lambda values: (0.94, 0.97, 0.99, 0.995),
            for vw in volw_grid: # Grid search on volatility-scaling windows: (0, 30, 60, 120)
                bt = EMA_OBV_Portfolio(
                    tickers, start, end,
                    lambda_=lam, weighted=weighted, vol_window=vw,
                    ma_window=ma_window, cost_per_turnover=cost_per_turnover,
                    target_ann_vol=target_ann_vol,
                    use_dual_ma=use_dual_ma,
                    allow_divergence_near_cross=allow_divergence_near_cross
                )
                bt.run(price=train_px, volume=volume.loc[train_px.index])
                m = calc_metrics(bt.portfolio["daily_return"], bt.portfolio["equity"], bt.initial_capital)
                if pd.notna(m["Sharpe"]) and m["Sharpe"] > best_sharpe:
                    best_sharpe = m["Sharpe"]
                    best = (lam, vw)

        lam_star, vw_star = best
        param_rows.append({"Year": y, "Best_lambda": lam_star, "Best_vol_window": vw_star})

        # Evaluate the best model on the Testing data - 1 year period after training data
        bt_test = EMA_OBV_Portfolio(
            tickers, start, end,
            lambda_=lam_star, weighted=weighted, vol_window=vw_star,
            ma_window=ma_window, cost_per_turnover=cost_per_turnover,
            target_ann_vol=target_ann_vol,
            use_dual_ma=use_dual_ma,
            allow_divergence_near_cross=allow_divergence_near_cross
        )
        bt_test.run(price=price.loc[test_px.index.union(train_px.index)],
                    volume=volume.loc[test_px.index.union(train_px.index)])

        eq_year  = bt_test.portfolio.loc[test_px.index, "equity"]
        ret_year = bt_test.portfolio.loc[test_px.index, "daily_return"]
        metrics  = calc_metrics(ret_year, eq_year, bt_test.initial_capital)

        yearly_rows.append({"Year": y, **metrics})
        stitched_eq = pd.concat([stitched_eq, eq_year])

    return pd.DataFrame(yearly_rows), stitched_eq, pd.DataFrame(param_rows)

