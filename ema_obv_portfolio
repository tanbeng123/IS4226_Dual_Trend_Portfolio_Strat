def plot_equity_vs_benchmark(equity, start, end, label="Strategy"):
    _, _, _, _, aligned = benchmark_compare(equity.pct_change().dropna(), start, end)
    bench_eq = (1 + aligned["Benchmark"]).cumprod() * 500000
    plt.figure(figsize=(12, 6))
    plt.plot(equity.index, equity, label=label, color="black")
    plt.plot(bench_eq.index, bench_eq, "--", color="grey", label="SPY Benchmark")
    plt.title(f"{label} vs SPY Benchmark")
    plt.ylabel("Equity ($)")
    plt.legend()
    plt.show()


def plot_underwater(equity):
    dd = equity / equity.cummax() - 1.0
    plt.figure(figsize=(12, 4))
    plt.fill_between(dd.index, dd, 0, color="#d62728", alpha=0.45)
    plt.title("Underwater Drawdown")
    plt.ylabel("Drawdown")
    plt.show()


def plot_yearly_segments(results_df, label="CAGR"):
    plt.figure(figsize=(10, 5))
    plt.bar(results_df["Year"], results_df["CAGR"] * 100, color="skyblue")
    plt.title("Yearly CAGR (%)")
    plt.xlabel("Year")
    plt.ylabel("Return %")
    plt.grid(True, axis="y")
    plt.show()


def performance_dashboard(portfolio_returns, equity, benchmark_returns=None, title_suffix=""):
    log_ret = np.log1p(portfolio_returns)
    cum_log = log_ret.cumsum()
    drawdown = (equity / equity.cummax()) - 1.0

    plt.figure(figsize=(18, 10))

    # 1) Cumulative Log Returns
    plt.subplot(2, 3, 1)
    plt.plot(cum_log, color="black", label="Cumulative Log Returns")
    plt.title("Cumulative Log Returns")
    plt.xlabel("Date")
    plt.ylabel("Log Return")
    plt.legend()
    plt.grid()

    # 2) Histogram
    plt.subplot(2, 3, 2)
    plt.hist(portfolio_returns, bins=30, color="skyblue", edgecolor="black", alpha=0.7)
    plt.title("Histogram of Daily Returns")
    plt.xlabel("Daily Return")
    plt.ylabel("Frequency")
    plt.grid()

    # 3) VS Benchmark
    plt.subplot(2, 3, 3)
    plt.plot((1 + portfolio_returns).cumprod(), label="Strategy", color="black")
    if benchmark_returns is not None:
        plt.plot((1 + benchmark_returns).cumprod(), label="SPY Benchmark", linestyle="--", color="grey")
    plt.title("Strategy vs SPY Benchmark")
    plt.xlabel("Date")
    plt.ylabel("Cumulative Return")
    plt.legend()
    plt.grid()

    # 4) Drawdown
    plt.subplot(2, 3, 4)
    plt.fill_between(drawdown.index, drawdown, 0, color="red", alpha=0.3)
    plt.plot(drawdown, color="red", linewidth=1.5)
    plt.title("Drawdown")
    plt.xlabel("Date")
    plt.ylabel("Drawdown")
    plt.grid()

    # 5) Equity Curve
    plt.subplot(2, 3, 5)
    plt.plot(equity, color="green", label="Equity ($)")
    plt.title("Portfolio Equity")
    plt.xlabel("Date")
    plt.ylabel("Equity ($)")
    plt.legend()
    plt.grid()

    plt.suptitle(f"Performance Dashboard {title_suffix}", fontsize=15, weight="bold")
    plt.tight_layout(rect=[0, 0, 1, 0.95])
    plt.tight_layout()
    plt.show()

# Strategy vs Benchmark reporter (DataFrame + single chart)
# ==========================================================
def report_and_compare_performance(strat_equities: dict, start, end,
                                   benchmark_symbol="SPY", init_cap=500000):
    """
    Build a metrics DataFrame for multiple strategies vs SPY and
    draw a compact side-by-side bar chart with a secondary y-axis for % metrics.
    Returns the metrics DataFrame (Total_Return, CAGR, Alpha, MaxDD already in %).
    """
    # Benchmark series
    bench = yf.download(benchmark_symbol, start=start, end=end,
                        progress=False, auto_adjust=True)
    spy_ret = bench["Close"].pct_change().dropna()
    spy_eq  = (1 + spy_ret).cumprod() * init_cap

    rows = []
    for name, eq in strat_equities.items():
        dr = eq.pct_change().dropna()
        m  = calc_metrics(dr, eq, init_cap)
        # Ensure Series into benchmark_compare
        a, b, ir, treynor, _ = benchmark_compare(dr.squeeze(), start, end, symbol=benchmark_symbol)
        rows.append({"Strategy": name, **m, "Alpha": a, "Beta": b, "Info_Ratio": ir, "Treynor": treynor})

    # Include SPY self-row (IR may be NaN vs itself; that's fine)
    spy_m  = calc_metrics(spy_ret, spy_eq, init_cap)
    spy_a, spy_b, spy_ir, spy_treynor, _ = benchmark_compare(spy_ret, start, end, symbol=benchmark_symbol)
    rows.append({"Strategy": f"{benchmark_symbol} (Benchmark)", **spy_m,
                 "Alpha": spy_a, "Beta": spy_b, "Info_Ratio": spy_ir, "Treynor": spy_treynor})

    df = pd.DataFrame(rows).set_index("Strategy")

    # ----- Plot grouped bars: ratios on left y-axis, % metrics on right -----
    ratio_metrics = ["Sharpe", "Sortino", "Calmar", "Info_Ratio", "Treynor", "Beta"]
    pct_metrics   = ["Total_Return", "CAGR", "Alpha", "MaxDD", "Ann_Mean", "Ann_Std_Dev"]

    cat_labels = ratio_metrics + pct_metrics
    x = np.arange(len(cat_labels))
    strategies = list(df.index)
    n = len(strategies)
    bar_w = 0.8 / max(n, 1)

    fig, ax1 = plt.subplots(figsize=(14, 6))
    ax2 = ax1.twinx()

    for i, s in enumerate(strategies):
        offset = (i - (n - 1) / 2) * bar_w

        left_vals  = [float(df.loc[s, m]) if pd.notna(df.loc[s, m]) else np.nan for m in ratio_metrics]
        right_vals = [float(df.loc[s, m] * 100) if pd.notna(df.loc[s, m]) else np.nan for m in pct_metrics]

        ax1.bar(x[:len(ratio_metrics)] + offset, left_vals, width=bar_w, label=s)
        ax2.bar(x[len(ratio_metrics):] + offset, right_vals, width=bar_w)

    ax1.set_ylabel("Ratios (Sharpe / Sortino / Calmar / IR / Treynor / Beta)")
    ax2.set_ylabel("Percent Metrics (%)  [Total Return, CAGR, Alpha, MaxDD, Ann_Mean, Ann_Std_Dev]", rotation=270, labelpad=18)

    ax1.set_xticks(x)
    ax1.set_xticklabels(ratio_metrics + [m + " (%)" for m in pct_metrics])
    ax1.axvline(x=len(ratio_metrics) - 0.5, color="grey", linestyle="--", alpha=0.6)

    handles, labels = ax1.get_legend_handles_labels()
    ax1.legend(handles, labels, ncol=min(n, 4), frameon=False, loc="upper left")

    ax1.grid(axis="y", linestyle="--", alpha=0.3)
    plt.title("Strategy Risk/Return Metrics vs Benchmark")
    plt.tight_layout()
    plt.show()

    # Return table with % columns already scaled for readability
    out = df.copy()
    for col in ["Total_Return", "CAGR", "Alpha", "MaxDD", "Ann_Mean", "Ann_Std_Dev"]:
        if col in out.columns:
            out[col] = out[col] * 100.0
    return out


# ==========================================================
# Function to run entire backtest (+ optional BOTH + internal comparison)
# ==========================================================
def run_backtest(start_date, end_date, stock_list, weighted,
                 lambda_best=0.990, vol_window_best=30, ma_window=50,
                 use_dual_ma=True, allow_div_near_cross=True,
                 target_ann_vol=0.20, cost_per_turnover=0.0,
                 include_attribution=True, plot_results=True,
                 compare_and_report=False,
                 benchmark_symbol="SPY", init_cap=500000):

    def _run_variant(weighted_flag: bool):
        # Run expanding-window backtest
        yearly_results, stitched_equity, yearly_params = expanding_window_test(
            stock_list, start_date, end_date, weighted=weighted_flag
        )

        # Daily Returns and Capital Changes
        daily = stitched_equity.pct_change().dropna()
        daily_equity = pd.DataFrame({
            "Equity": stitched_equity,
            "Daily_Return": stitched_equity.pct_change()
        })
        daily_equity.index.name = "Date"
        print(f"\n=== Sample of Daily Capital Changes ({'Weighted' if weighted_flag else 'Unweighted'}) ===")
        print(daily_equity.tail(10))

        # Compute Overall Performance Metrics
        metrics = calc_metrics(daily, stitched_equity, init_cap=init_cap)
        alpha, beta, ir, treynor, _ = benchmark_compare(daily, start_date, end_date, symbol=benchmark_symbol)
        metrics["Volatility"] = daily.std() * np.sqrt(252)
        metrics["MaxDD_Duration_Days"] = max_drawdown_duration(stitched_equity)

        # Print Summary Metrics
        variant = "Weighted" if weighted_flag else "Unweighted"
        final_equity = stitched_equity.iloc[-1]

        print(f"\n{'='*65}")
        print(f"=== Final Performance Summary for {variant} OBV-EMA Strategy ===")
        print(f"{'Total Return':22}: {metrics['Total_Return']*100:8.2f} %")
        print(f"{'CAGR':22}: {metrics['CAGR']*100:8.2f} %")
        print(f"{'Annual Volatility':22}: {metrics['Volatility']*100:8.2f} %")
        print(f"{'Sharpe Ratio':22}: {metrics['Sharpe']:10.3f}")
        print(f"{'Sortino Ratio':22}: {metrics['Sortino']:10.3f}")
        print(f"{'Calmar Ratio':22}: {metrics['Calmar']:10.3f}")
        print(f"{'Max Drawdown':22}: {metrics['MaxDD']*100:8.2f} %")
        print(f"{'Max DD Duration':22}: {metrics['MaxDD_Duration_Days']:10} days")
        print(f"{'Alpha':22}: {alpha*100:8.2f} %")
        print(f"{'Beta':22}: {beta:10.3f}")
        print(f"{'Info Ratio':22}: {ir:10.3f}")
        print(f"{'Treynor Ratio':22}: {treynor:10.3f}")
        print(f"{'Final Equity ($)':22}: {final_equity:10,.2f}")

        # Optional Short-Term ROI (last 6 months)
        if len(stitched_equity) > 252:
            sub_ret = (stitched_equity.iloc[-125] / stitched_equity.iloc[-252]) - 1
            print(f"Approx. 6-Month Return before {end_date}: {sub_ret*100:.2f} %")

        # Visualisation: Plot results
        if plot_results:
            plot_equity_vs_benchmark(stitched_equity, start_date, end_date, label=f"{variant} OBV-EMA")
            plot_underwater(stitched_equity)
            plot_yearly_segments(yearly_results, label="CAGR")
            performance_dashboard(daily, stitched_equity)

        # Optional Per-Ticker Attribution
        if include_attribution:
            bt_full = EMA_OBV_Portfolio(
                stock_list, start_date, end_date,
                lambda_=lambda_best, weighted=weighted_flag, vol_window=vol_window_best,
                ma_window=ma_window, use_dual_ma=use_dual_ma,
                allow_divergence_near_cross=allow_div_near_cross,
                target_ann_vol=target_ann_vol, cost_per_turnover=cost_per_turnover
            )
            bt_full.run()
            attr = per_ticker_attribution(bt_full.price, bt_full.positions)
            print("\n=== Per-Ticker Contribution (table) ===")
            print(attr.sort_values("Return_Contribution", ascending=False))
            plot_per_ticker_attribution(bt_full.price, bt_full.positions)

            # Trade Statistics
            trade_stats = trade_statistics(bt_full.positions, bt_full.price)
            print("\n=== Trade Statistics Summary ===")
            for k, v in trade_stats.items():
                if isinstance(v, (int, np.integer)):
                    print(f"{k:20}: {v}")
                else:
                    print(f"{k:20}: {v*100:.2f} %" if "Rate" in k else f"{k:20}: {v:.4f}")
            metrics.update(trade_stats)

        return yearly_results, stitched_equity, yearly_params, metrics, daily_equity

    # Run both variants in one call
    if isinstance(weighted, str) and weighted.lower() == "both":
        uw_yearly, uw_eq, uw_params, uw_metrics, uw_daily = _run_variant(False)
        print("\n")
        w_yearly, w_eq, w_params, w_metrics, w_daily   = _run_variant(True)

        compare_df = None
        if compare_and_report:
            compare_df = report_and_compare_performance(
                strat_equities={
                    "OBV-EMA (Unweighted)": uw_eq,
                    "OBV-EMA (Weighted)"  : w_eq
                },
                start=start_date, end=end_date,
                benchmark_symbol=benchmark_symbol, init_cap=init_cap
            )
            print("\n=== Strategy vs SPY Performance (%, ratios as-is) ===")
            print(compare_df.round(3))

        # return a structured dict to keep everything accessible
        return {
            "unweighted": {"yearly": uw_yearly, "equity": uw_eq, "params": uw_params, "metrics": uw_metrics, "daily": uw_daily},
            "weighted":   {"yearly": w_yearly,  "equity": w_eq,  "params": w_params,  "metrics": w_metrics, "daily": w_daily},
            "compare_df": compare_df
        }

    # Single-Variant behaviour
    return _run_variant(bool(weighted))
